{
  "name": "meralco-monitoring",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install-all": "npm install",
    "start": "npm --workspace backend start",
    "dev": "npm --workspace frontend run dev",
    "dev-all": "concurrently \"npm --workspace backend start\" \"npm --workspace frontend run dev\"",
    "start-all": "npm run dev-all",
    "start-backend": "npm --workspace backend start",
    "start-frontend": "npm --workspace frontend run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
